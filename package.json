{
  "name": "fitero",
  "version": "0.1.0",
  "description": "AI fitness action-agent with tool-calling and Google Calendar",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "concurrently \"tsx watch src/server.ts\" \"npm run dev --prefix client\"",
    "terminal": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "open": "^11.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
